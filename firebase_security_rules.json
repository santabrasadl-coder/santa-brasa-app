{
  "rules": {
    ".read": false,
    ".write": false,
    "orders": {
      ".read": true,
      ".indexOn": ["timestamp"],
      "$order_id": {
        ".write": "!data.exists()",
        ".validate": "newData.hasChildren(['items', 'total', 'customer'])"
      }
    },
    "metrics": {
      ".read": true,
      "totals": {
        "$metric": {
          ".write": "true"
        }
      },
      "$date": {
        "$metric": {
          ".write": "true"
        }
      }
    },
    "presence": {
      "users": {
        ".read": true,
        "$id": { ".write": "true" }
      },
      "admins": {
        ".read": true,
        "$id": { ".write": "true" }
      }
    },
    "logs": {
      ".read": true,
      ".write": "true"
    },
    "customers": {
      ".read": true,
      ".write": "true"
    },
    "settings": {
      ".read": true,
      ".write": "true"
    },
    "chats": {
      "$session_id": {
        ".read": true,
        ".write": true
      }
    }
  }
}